generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SELLER
  CUSTOMER
  BUYER
}

enum OrderStatus {
  PENDING
  APPROVED
  REJECTED
  DONE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  VERIFIED
  REJECTED
}

enum AuctionStatus {
  ACTIVE
  ENDED
  CANCELLED
}

model User {
  id              String    @id @default(cuid())
  username        String    @unique
  firstName       String
  lastName        String
  email           String    @unique
  phone           String?
  whatsapp        String?
  address         String?
  password        String
  role            UserRole  @default(CUSTOMER)
  isActive        Boolean   @default(true)
  kycVerified     Boolean   @default(false)
  kycDocUrl       String?
  kycFaceUrl      String?
  phoneVerified   Boolean   @default(false)
  language        String    @default("en")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  products        Product[]
  ordersAsCustomer Order[]  @relation("CustomerOrders")
  ordersAsSeller  Order[]   @relation("SellerOrders")
  bankAccounts    BankAccount[]
  paymentRequests PaymentRequest[]
  auctionBids     AuctionBid[]
  announcements   AnnouncementRecipient[]
  store           Store?
  earnings        Earning[]
  otpCodes        OtpCode[]
  passwordResets  PasswordReset[]
}

model OtpCode {
  id        String   @id @default(cuid())
  userId    String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id        String    @id @default(cuid())
  name      String
  nameEn    String?
  nameSi    String?
  nameTa    String?
  slug      String    @unique
  isVisible Boolean   @default(true)
  icon      String?
  createdAt DateTime  @default(now())
  products  Product[]
}

model Product {
  id            String   @id @default(cuid())
  title         String
  titleSi       String?
  titleTa       String?
  description   String?
  descriptionSi String?
  descriptionTa String?
  basePrice     Float
  finalPrice    Float
  profitPercent Float    @default(0)
  imageUrl      String?
  images        String[]
  stock         Int      @default(0)
  isActive      Boolean  @default(true)
  categoryId    String?
  sellerId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category  Category?   @relation(fields: [categoryId], references: [id])
  seller    User        @relation(fields: [sellerId], references: [id])
  orderItems OrderItem[]
  auctionItems AuctionItem[]
}

model Order {
  id          String      @id @default(cuid())
  customerId  String
  sellerId    String
  status      OrderStatus @default(PENDING)
  totalAmount Float
  note        String?
  rejectReason String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  customer    User        @relation("CustomerOrders", fields: [customerId], references: [id])
  seller      User        @relation("SellerOrders", fields: [sellerId], references: [id])
  items       OrderItem[]
  payment     Payment?
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Payment {
  id        String        @id @default(cuid())
  orderId   String        @unique
  amount    Float
  status    PaymentStatus @default(PENDING)
  receiptUrl String?
  paidAt    DateTime?
  createdAt DateTime      @default(now())

  order     Order         @relation(fields: [orderId], references: [id])
}

model BankAccount {
  id          String  @id @default(cuid())
  userId      String
  bankName    String
  accountNo   String
  accountName String
  isDefault   Boolean @default(false)
  createdAt   DateTime @default(now())

  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PaymentRequest {
  id        String        @id @default(cuid())
  sellerId  String
  bankName  String
  accountNo String
  amount    Float
  status    PaymentStatus @default(PENDING)
  createdAt DateTime      @default(now())

  seller    User          @relation(fields: [sellerId], references: [id])
}

model Store {
  id          String  @id @default(cuid())
  userId      String  @unique
  name        String
  description String?
  logoUrl     String?
  bannerUrl   String?
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())

  user        User    @relation(fields: [userId], references: [id])
}

model Earning {
  id        String   @id @default(cuid())
  userId    String
  orderId   String?
  amount    Float
  type      String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  message   String
  createdAt DateTime @default(now())

  recipients AnnouncementRecipient[]
}

model AnnouncementRecipient {
  id             String @id @default(cuid())
  announcementId String
  userId         String
  isRead         Boolean @default(false)

  announcement   Announcement @relation(fields: [announcementId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
}

model Auction {
  id          String        @id @default(cuid())
  title       String
  description String?
  startPrice  Float
  currentBid  Float?
  minBidStep  Float         @default(10)
  adminProfit Float         @default(5)
  startTime   DateTime
  endTime     DateTime
  status      AuctionStatus @default(ACTIVE)
  createdBy   String
  winnerId    String?
  createdAt   DateTime      @default(now())

  items       AuctionItem[]
  bids        AuctionBid[]
}

model AuctionItem {
  id        String  @id @default(cuid())
  auctionId String
  productId String

  auction   Auction @relation(fields: [auctionId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model AuctionBid {
  id        String   @id @default(cuid())
  auctionId String
  userId    String
  amount    Float
  createdAt DateTime @default(now())

  auction   Auction  @relation(fields: [auctionId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model GlobalSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
